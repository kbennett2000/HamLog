# Database connection (matches docker-compose.yml defaults)
DB_HOST=localhost
DB_USER=hamlog
DB_PASSWORD=hamlog_pw
DB_NAME=HamLogDB
DB_ROOT_PASSWORD=changeme

# Backend server port
PORT=7800

# API key for write endpoints (set to any secret string)
API_KEY=changeme

# CORS allowed origin (use * for development, restrict in production)
CORS_ORIGIN=*
