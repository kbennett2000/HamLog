# Database connection
# DB_PASSWORD and DB_ROOT_PASSWORD are REQUIRED — compose refuses to start if unset.
# Generate strong values with: openssl rand -base64 24
DB_HOST=localhost
DB_USER=hamlog
DB_PASSWORD=
DB_NAME=HamLogDB
DB_ROOT_PASSWORD=

# Backend server port
PORT=8050

# JWT secret (REQUIRED — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=changeme-generate-a-random-secret

# CORS: leave UNSET for the default same-origin setup (the SPA is served by this
# server, so no CORS is needed). Only set this if you run a SEPARATE-ORIGIN client,
# e.g. CORS_ORIGIN=http://192.168.1.50:3000 (comma-separate multiple origins).
# Do NOT use *.
CORS_ORIGIN=
