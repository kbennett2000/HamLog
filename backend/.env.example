# Database connection (matches docker-compose.yml defaults)
DB_HOST=localhost
DB_USER=hamlog
DB_PASSWORD=hamlog_pw
DB_NAME=HamLogDB
DB_ROOT_PASSWORD=changeme

# Backend server port
PORT=8050

# JWT secret (REQUIRED — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=changeme-generate-a-random-secret

# CORS allowed origin (use * for development, restrict in production)
CORS_ORIGIN=*
